{
  "id": null,
  "uid": "restaurant-otel",
  "title": "Restaurante - OpenTelemetry Dashboard",
  "tags": ["restaurant", "opentelemetry", "sre"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests por Segundo (RPS) - order-service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(restaurant_restaurant_orders_total_total[1m])",
          "legendFormat": "RPS - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Latencia de Órdenes - Percentil p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(restaurant_restaurant_order_duration_ms_bucket[5m]))",
          "legendFormat": "p95 latency"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, rate(restaurant_restaurant_order_duration_ms_bucket[5m]))",
          "legendFormat": "p50 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Órdenes Recibidas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(restaurant_restaurant_orders_total_total)",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Órdenes Fallidas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(restaurant_restaurant_orders_failed_total)",
          "legendFormat": "Fallidas"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Tasa de Error (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum(restaurant_restaurant_orders_failed_total) / (sum(restaurant_restaurant_orders_total_total) > 0)",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Órdenes Activas en Procesamiento",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(restaurant_restaurant_orders_active_total)",
          "legendFormat": "Activas"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 7,
      "title": "METRICA CUSTOM: Valor de Órdenes en COP (p95)",
      "description": "Percentil p95 del valor monetario de cada orden procesada. Métrica custom: restaurant.order.value",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(restaurant_restaurant_order_value_COP_bucket[5m]))",
          "legendFormat": "p95 valor orden (COP)"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(restaurant_restaurant_order_value_COP_sum[1m]) / rate(restaurant_restaurant_order_value_COP_count[1m])",
          "legendFormat": "Valor promedio por orden (COP)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 8,
      "title": "METRICA CUSTOM: Platos más Solicitados",
      "description": "Conteo de solicitudes por plato en kitchen-service. Métrica custom: restaurant.kitchen.dish_requests",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (dish) (restaurant_restaurant_kitchen_dish_requests_total)",
          "legendFormat": "{{dish}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 9,
      "title": "Latencia de Consultas DB - kitchen-service (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, rate(restaurant_restaurant_kitchen_db_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95 DB latency - {{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 10,
      "title": "Consultas DB por operación",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(restaurant_restaurant_kitchen_db_queries_total[1m])",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 11,
      "title": "Errores kitchen-service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(restaurant_restaurant_kitchen_errors_total[1m])",
          "legendFormat": "Errores/s - {{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      }
    },
    {
      "id": 12,
      "title": "Memoria del OTel Collector",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "otelcol_process_memory_rss",
          "legendFormat": "OTel Collector RSS"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
